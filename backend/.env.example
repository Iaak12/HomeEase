# ─────────────────────────────────────────────────────────────
#  HomeEase Backend — Environment Variables
#  Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# 1. Go to https://cloud.mongodb.com
# 2. Create a free cluster → Connect → Drivers → copy the URI
# 3. Replace <username>, <password>, <cluster> with yours
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/homeease?retryWrites=true&w=majority

# JWT Secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_EXPIRE=7d

# Google OAuth 2.0
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend URL (used for CORS and OAuth redirect after login)
CLIENT_URL=http://localhost:5173

# Admin seed — used by scripts/seedAdmin.js
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@homeease.com
ADMIN_PASSWORD=Admin@123456
